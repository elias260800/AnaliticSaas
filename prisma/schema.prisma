datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)
  slug       String   @unique @db.VarChar(100)
  plan       String   @default("free") @db.VarChar(50) // 'free', 'starter', 'professional', 'enterprise'
  settings   Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users         User[]
  roles         Role[]
  subscriptions Subscription[]
  metricEvents  MetricEvent[]
  clients       Client[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  assignedRoles UserRole[]     @relation("AssignedBy")

  @@unique([email, tenantId], name: "uq_users_email_tenant")
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // NULL = global system role
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([name, tenantId], name: "uq_roles_name_tenant")
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  resource    String   @db.VarChar(100) // e.g. 'users', 'billing'
  action      String   @db.VarChar(50)  // e.g. 'read', 'write'
  description String?  @db.Text

  rolePermissions RolePermission[]

  @@unique([resource, action], name: "uq_permissions_resource_action")
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  assignedBy String?  @map("assigned_by") @db.Uuid

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner   User? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceInfo Json      @default("{}") @map("device_info")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==========================================
// MODELOS PARA FASES 2-3 Y 4 (DASHBOARD & CRM)
// ==========================================

model Subscription {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  clientId           String    @map("client_id") @db.Uuid
  planName           String    @map("plan_name") @db.VarChar(100)
  status             String    @default("active") @db.VarChar(30)
  mrrCents           Int       @default(0) @map("mrr_cents")
  currency           String    @default("USD") @db.VarChar(3)
  startedAt          DateTime  @map("started_at") @db.Timestamptz
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz
  trialEndsAt        DateTime? @map("trial_ends_at") @db.Timestamptz
  currentPeriodStart DateTime  @map("current_period_start") @db.Timestamptz
  currentPeriodEnd   DateTime  @map("current_period_end") @db.Timestamptz
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model MetricEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(50)
  amountCents Int      @default(0) @map("amount_cents")
  currency    String   @default("USD") @db.VarChar(3)
  region      String?  @db.VarChar(50)
  planName    String?  @map("plan_name") @db.VarChar(100)
  metadata    Json     @default("{}")
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("metric_events")
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  legalName String   @map("legal_name") @db.VarChar(300)
  tradeName String?  @map("trade_name") @db.VarChar(300)
  taxId     String   @map("tax_id") @db.VarChar(50)
  country   String   @db.VarChar(3)
  region    String?  @db.VarChar(100)
  industry  String?  @db.VarChar(100)
  website   String?  @db.VarChar(500)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  status    String   @default("active") @db.VarChar(30)
  notes     String?  @db.Text
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billing       ClientBilling?
  planConfig    ClientPlanConfig?
  contacts      ClientContact[]
  subscriptions Subscription[]

  @@unique([taxId, tenantId], name: "uq_clients_tax_id_tenant")
  @@map("clients")
}

model ClientBilling {
  id             String   @id @default(uuid()) @db.Uuid
  clientId       String   @unique @map("client_id") @db.Uuid
  billingEmail   String   @map("billing_email") @db.VarChar(255)
  billingAddress String   @map("billing_address") @db.Text
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  postalCode     String?  @map("postal_code") @db.VarChar(20)
  country        String   @db.VarChar(3)
  currency       String   @default("USD") @db.VarChar(3)
  paymentMethod  String   @default("bank_transfer") @map("payment_method") @db.VarChar(50)
  taxExempt      Boolean  @default(false) @map("tax_exempt")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_billing")
}

model ClientContact {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  firstName String   @map("first_name") @db.VarChar(100)
  lastName  String   @map("last_name") @db.VarChar(100)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(30)
  role      String   @db.VarChar(50)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

model ClientPlanConfig {
  id             String    @id @default(uuid()) @db.Uuid
  clientId       String    @unique @map("client_id") @db.Uuid
  planName       String    @map("plan_name") @db.VarChar(100)
  userLimit      Int       @map("user_limit")
  storageLimitGb Int       @map("storage_limit_gb")
  startedAt      DateTime  @map("started_at") @db.Date
  isTrial        Boolean   @default(false) @map("is_trial")
  trialDays      Int?      @default(0) @map("trial_days")
  trialEndsAt    DateTime? @map("trial_ends_at") @db.Date
  customFeatures Json      @default("{}") @map("custom_features")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_plan_configs")
}
